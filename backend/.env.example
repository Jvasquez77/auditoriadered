# Copiar a .env y ajustar valores locales
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/network_audit_db

# Umbrales operacionales (sobreescribir en producción si cambian)
OTDR_MAX_FUSION_LOSS_DB=0.1
SFP_MIN_TX_POWER_DBM=6.0
CLIENT_AVG_MIN_POWER_DBM=-26.5
CLIENT_CRITICAL_POWER_DBM=-25.4
CLIENT_CRITICAL_SEVERE_POWER_DBM=-27.01
RESERVE_BOX_METERS=15.0
RESERVE_POLE_METERS=40.0
RESERVE_POLE_INTERVAL_METERS=400.0

DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
MEDIA_DIR=media
BASE_MEDIA_URL=http://localhost:8000/media
